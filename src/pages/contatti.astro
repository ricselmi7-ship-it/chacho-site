---
import Layout from "~/layouts/Layout.astro";
---

<Layout title="Contatti — Chacho">
  <header class="mb-12">
    <p class="text-[10px] uppercase tracking-[0.3em] text-muted">
      Get in touch
    </p>
    <h1 class="mt-3 font-raw text-5xl uppercase tracking-tight md:text-7xl">
      Contatti
    </h1>
  </header>

  <div class="grid gap-12 md:grid-cols-2">
    <section>
      <h2 class="text-[10px] uppercase tracking-[0.3em] text-muted">
        Booking
      </h2>
      <a
        href="mailto:ricselmi7@gmail.com"
        class="mt-3 block font-raw text-2xl uppercase tracking-wide text-accent md:text-3xl"
      >
        ricselmi7@gmail.com
      </a>
    </section>

    <section>
      <h2 class="text-[10px] uppercase tracking-[0.3em] text-muted">
        Instagram
      </h2>
      <a
        href="https://www.instagram.com/chacho.project"
        target="_blank"
        rel="noopener"
        class="mt-3 block font-raw text-2xl uppercase tracking-wide text-accent md:text-3xl"
      >
        @chacho.project
      </a>
    </section>
  </div>
</Layout>
