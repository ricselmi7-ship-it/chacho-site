---
import Layout from "~/layouts/Layout.astro";
---

<Layout title="Contatti — Chacho">
  <header class="mb-12">
    <p class="text-xs uppercase tracking-widest text-muted">Get in touch</p>
    <h1 class="mt-3 font-display text-4xl md:text-6xl">Contatti</h1>
  </header>

  <div class="grid gap-12 md:grid-cols-2">
    <section>
      <h2 class="text-xs uppercase tracking-widest text-muted">Booking</h2>
      <a
        href="mailto:booking@notte.example"
        class="mt-3 block font-display text-2xl text-accent"
      >
        booking@notte.example
      </a>
    </section>

    <section>
      <h2 class="text-xs uppercase tracking-widest text-muted">Press</h2>
      <a
        href="mailto:press@notte.example"
        class="mt-3 block font-display text-2xl text-accent"
      >
        press@notte.example
      </a>
    </section>

    <section class="md:col-span-2">
      <h2 class="text-xs uppercase tracking-widest text-muted">Social</h2>
      <ul class="mt-3 flex flex-wrap gap-6 font-display text-xl">
        <li><a href="#" class="text-bone">Instagram</a></li>
        <li><a href="#" class="text-bone">Resident Advisor</a></li>
        <li><a href="#" class="text-bone">SoundCloud</a></li>
      </ul>
    </section>
  </div>
</Layout>
