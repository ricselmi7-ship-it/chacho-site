---
import Layout from "~/layouts/Layout.astro";
import Ticker from "~/components/Ticker.astro";
import galleryData from "~/data/gallery.json";
import type { GalleryItem, GalleryEvent } from "~/types";

const items = galleryData as GalleryItem[];

const byEvent = new Map<string, GalleryEvent>();
for (const item of items) {
  if (!byEvent.has(item.evento)) {
    byEvent.set(item.evento, {
      evento: item.evento,
      data: item.data,
      luogo: item.luogo,
      descrizione: item.descrizione,
      cover: item,
      items: [],
    });
  }
  const ev = byEvent.get(item.evento)!;
  ev.items.push(item);
  if (item.cover) ev.cover = item;
}

const events = Array.from(byEvent.values()).sort(
  (a, b) => +new Date(b.data) - +new Date(a.data),
);

const formatData = (d: string) =>
  new Date(d).toLocaleDateString("it-IT", {
    day: "numeric",
    month: "long",
    year: "numeric",
  });
---

<Layout title="Gallery — Chacho" description="Archivio fotografico degli eventi.">
  <div class="-mx-6 -mt-28 md:-mt-32">
    <Ticker text="Gallery ☀ " speed={30} />
  </div>

  <header class="mt-16 mb-12">
    <p class="text-xs uppercase tracking-[0.3em] text-muted">Archivio</p>
    <h1 class="mt-3 font-display text-4xl uppercase md:text-6xl">
      Gallery
    </h1>
  </header>

  <section class="grid gap-1 md:grid-cols-2">
    {
      events.map((event) => (
        <button
          type="button"
          class="event-cover group relative block aspect-[4/3] overflow-hidden bg-white/5 text-left"
          data-event={event.evento}
        >
          <img
            src={event.cover.src}
            alt={event.evento}
            loading="lazy"
            class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-ink via-ink/40 to-transparent" />
          <div class="absolute inset-x-0 bottom-0 p-6 md:p-8">
            <p class="text-[10px] uppercase tracking-[0.3em] text-accent">
              {formatData(event.data)}
            </p>
            <h2 class="mt-2 font-display text-2xl uppercase leading-tight text-bone md:text-3xl">
              {event.evento}
            </h2>
            <p class="mt-1 text-xs uppercase tracking-widest text-muted">
              {event.luogo}
            </p>
          </div>
        </button>
      ))
    }
  </section>

  <dialog
    id="lightbox"
    class="w-full max-w-5xl border border-white/10 bg-ink p-0 text-bone backdrop:bg-black/90"
    aria-labelledby="lightbox-title"
  >
    <div class="relative">
      <button
        type="button"
        id="lightbox-close"
        aria-label="Chiudi"
        class="absolute right-4 top-4 z-10 flex h-10 w-10 items-center justify-center border border-white/20 text-bone hover:bg-bone hover:text-ink"
      >
        ✕
      </button>
      <div id="lightbox-content" class="p-6 md:p-10"></div>
    </div>
  </dialog>
</Layout>

<style is:global>
  #lightbox {
    color-scheme: dark;
  }
  #lightbox::backdrop {
    backdrop-filter: blur(4px);
  }
  #lightbox[open] {
    margin: auto;
  }
</style>

<script define:vars={{ eventsData: events }}>
  const dialog = document.getElementById("lightbox");
  const content = document.getElementById("lightbox-content");
  const closeBtn = document.getElementById("lightbox-close");

  const formatData = (d) =>
    new Date(d).toLocaleDateString("it-IT", {
      day: "numeric",
      month: "long",
      year: "numeric",
    });

  const escape = (s) =>
    String(s).replace(
      /[&<>"']/g,
      (c) =>
        ({
          "&": "&amp;",
          "<": "&lt;",
          ">": "&gt;",
          '"': "&quot;",
          "'": "&#39;",
        })[c],
    );

  const renderItem = (item) => {
    if (item.tipo === "video") {
      return `
        <div class="bg-black">
          <video
            src="${escape(item.src)}"
            controls
            preload="metadata"
            class="block h-auto w-full"
          ></video>
        </div>
      `;
    }
    return `
      <img
        src="${escape(item.src)}"
        alt=""
        loading="lazy"
        class="block h-auto w-full"
      />
    `;
  };

  const openEvent = (eventName) => {
    const event = eventsData.find((e) => e.evento === eventName);
    if (!event) return;
    const media = event.items.map(renderItem).join("");
    content.innerHTML = `
      <header class="mb-8 max-w-3xl">
        <p class="text-[10px] uppercase tracking-[0.3em] text-[color:var(--color-accent)]">
          ${escape(formatData(event.data))} · ${escape(event.luogo)}
        </p>
        <h2 id="lightbox-title" class="mt-3 font-display text-3xl uppercase leading-tight md:text-5xl">
          ${escape(event.evento)}
        </h2>
        <p class="mt-4 text-sm leading-relaxed text-[color:var(--color-bone)]/80">
          ${escape(event.descrizione)}
        </p>
      </header>
      <div class="grid gap-1 md:grid-cols-2">${media}</div>
    `;
    dialog.showModal();
  };

  document.querySelectorAll(".event-cover").forEach((btn) => {
    btn.addEventListener("click", () => openEvent(btn.dataset.event));
  });

  closeBtn?.addEventListener("click", () => dialog.close());

  dialog.addEventListener("click", (e) => {
    if (e.target === dialog) dialog.close();
  });

  dialog.addEventListener("close", () => {
    content.innerHTML = "";
  });
</script>
