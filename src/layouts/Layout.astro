---
import "~/styles/global.css";
import Navbar from "~/components/Navbar.astro";
import Footer from "~/components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  heroMode?: boolean;
}

const {
  title = "Sito Musicale — Eventi",
  description = "Calendario eventi, line-up e biglietti.",
  heroMode = false,
} = Astro.props;
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500&family=Playfair+Display:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="bg-ink text-bone">
    <Navbar transparent={heroMode} />
    {
      heroMode ? (
        <main>
          <slot />
        </main>
      ) : (
        <main class="mx-auto max-w-6xl px-6 pt-28 pb-12 md:pt-32 md:pb-20">
          <slot />
        </main>
      )
    }
    <Footer />
  </body>
</html>
