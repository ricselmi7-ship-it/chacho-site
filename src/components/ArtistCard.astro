---
import type { Artista } from "~/types";

interface Props {
  artista: Artista;
}

const { artista } = Astro.props;
---

<article class="border-t border-white/5 py-8">
  <h3 class="font-display text-2xl text-bone">{artista.nome}</h3>
  <p class="mt-1 text-xs uppercase tracking-widest text-muted">
    {artista.ruolo}
  </p>
  <p class="mt-3 max-w-prose text-sm text-bone/80">{artista.bio}</p>
  {
    artista.link && (
      <a
        href={artista.link}
        target="_blank"
        rel="noopener"
        class="mt-3 inline-block text-xs uppercase tracking-widest text-accent"
      >
        Ascolta →
      </a>
    )
  }
</article>
