---
const year = new Date().getFullYear();

const navLinks = [
  { href: "/eventi", label: "Eventi" },
  { href: "/gallery", label: "Gallery" },
  { href: "/manifesto", label: "Manifesto" },
  { href: "/contatti", label: "Contatti" },
];

const socials = [
  {
    label: "Instagram",
    href: "https://instagram.com/",
    icon: "instagram",
  },
  { label: "Email", href: "mailto:booking@chacho.example", icon: "mail" },
  { label: "WhatsApp", href: "https://wa.me/", icon: "whatsapp" },
  {
    label: "Resident Advisor",
    href: "https://ra.co/",
    icon: "ra",
  },
];
---

<footer class="bg-ink pt-24 pb-10 md:pt-32">
  <div class="mx-auto flex max-w-6xl flex-col items-center gap-12 px-6">
    <a href="/" aria-label="Chacho — home" class="block">
      <img
        src="/logo.png"
        alt="Chacho"
        width="180"
        height="50"
        class="h-10 w-auto invert md:h-12"
      />
    </a>

    <nav aria-label="Footer">
      <ul
        class="flex flex-wrap items-center justify-center gap-6 md:gap-10"
      >
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-[11px] uppercase tracking-[0.25em] text-muted hover:text-bone"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <ul class="flex items-center gap-6">
      {
        socials.map((s) => (
          <li>
            <a
              href={s.href}
              aria-label={s.label}
              target="_blank"
              rel="noopener"
              class="flex h-10 w-10 items-center justify-center border border-white/15 text-muted hover:border-bone hover:text-bone"
            >
              {s.icon === "instagram" && (
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.6"
                >
                  <rect x="3" y="3" width="18" height="18" rx="4" />
                  <circle cx="12" cy="12" r="4" />
                  <circle cx="17.5" cy="6.5" r="0.9" fill="currentColor" />
                </svg>
              )}
              {s.icon === "mail" && (
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.6"
                >
                  <rect x="3" y="5" width="18" height="14" />
                  <path d="M3 6l9 7 9-7" />
                </svg>
              )}
              {s.icon === "whatsapp" && (
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.6"
                >
                  <path d="M21 12a9 9 0 1 1-3.7-7.3L21 4l-1 4.3A9 9 0 0 1 21 12z" />
                  <path d="M8 11.5c0 3 2.5 5.5 5.5 5.5l1.5-1.8-2-1-1 .6c-1 .2-2.5-1.3-2.7-2.3l.6-1-1-2L7 9.5C7 10 8 11 8 11.5z" />
                </svg>
              )}
              {s.icon === "ra" && (
                <span class="font-raw text-sm tracking-wider">RA</span>
              )}
            </a>
          </li>
        ))
      }
    </ul>

    <p class="text-[10px] uppercase tracking-[0.3em] text-muted">
      © {year} Chacho — All rights reserved
    </p>
  </div>
</footer>
