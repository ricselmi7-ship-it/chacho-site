---
import type { Evento } from "~/types";
import { formatGiorno, formatMese, formatLuogo } from "~/lib/format";

interface Props {
  evento: Evento;
}

const { evento } = Astro.props;
const hasArtisti = evento.artisti && evento.artisti.length > 0;
const hasPartner = evento.partner && evento.partner.length > 0;
---

<a
  href={`/eventi/${evento.slug}`}
  class="group block border-t border-white/5 py-8 md:grid md:grid-cols-12 md:gap-8"
>
  <div class="md:col-span-2">
    <div class="font-raw text-4xl text-accent md:text-5xl">
      {formatGiorno(evento.data)}
    </div>
    <div class="text-[10px] uppercase tracking-[0.3em] text-muted">
      {formatMese(evento.data)} {new Date(evento.data).getFullYear()}
    </div>
  </div>

  <div class="mt-4 md:col-span-7 md:mt-0">
    <h3
      class="font-raw text-2xl uppercase leading-tight text-bone md:text-3xl"
    >
      {evento.titolo}
    </h3>
    {
      evento.sottotitolo && (
        <p class="mt-1 text-[10px] uppercase tracking-[0.3em] text-accent">
          {evento.sottotitolo}
        </p>
      )
    }
    <p class="mt-2 text-[10px] uppercase tracking-[0.3em] text-muted">
      {formatLuogo(evento)} · {evento.orario}
    </p>

    {
      hasArtisti && (
        <p class="mt-3 text-xs uppercase tracking-[0.15em] text-bone/80">
          <span class="text-muted">Feat. </span>
          {evento.artisti.join(" · ")}
        </p>
      )
    }

    {
      hasPartner && (
        <p class="mt-1.5 text-[10px] uppercase tracking-[0.2em] text-muted">
          <span class="text-accent">With</span>{" "}
          {evento.partner!.join(" × ")}
        </p>
      )
    }
  </div>

  <div
    class="mt-4 flex items-start justify-start md:col-span-3 md:mt-0 md:justify-end"
  >
    <span
      class="text-[10px] uppercase tracking-[0.3em] text-muted transition-colors group-hover:text-accent"
    >
      Dettagli →
    </span>
  </div>
</a>
