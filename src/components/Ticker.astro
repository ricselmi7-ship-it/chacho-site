---
interface Props {
  text: string;
  speed?: number;
  direction?: "left" | "right";
  variant?: "default" | "raw";
}

const {
  text,
  speed = 40,
  direction = "left",
  variant = "default",
} = Astro.props;

const items = Array.from({ length: 10 }, () => text);
---

<div
  class:list={[
    "ticker",
    variant === "raw" ? "ticker--raw" : "ticker--default",
    direction === "right" ? "ticker--right" : "ticker--left",
  ]}
  aria-hidden="true"
  style={`--ticker-speed: ${speed}s`}
>
  <div class="ticker-track">
    {
      items.map((t) => (
        <span class="ticker-item">
          {t}
          <span class="ticker-dot">✦</span>
        </span>
      ))
    }
  </div>
</div>

<style>
  .ticker {
    overflow: hidden;
    background: var(--color-ink);
  }
  .ticker--default {
    border-top: 1px solid rgba(240, 237, 232, 0.08);
    border-bottom: 1px solid rgba(240, 237, 232, 0.08);
    padding: 1.25rem 0;
  }
  .ticker--raw {
    padding: 1rem 0;
  }
  .ticker-track {
    display: flex;
    gap: 2.5rem;
    width: max-content;
    will-change: transform;
  }
  .ticker--left .ticker-track {
    animation: ticker-left var(--ticker-speed, 40s) linear infinite;
  }
  .ticker--right .ticker-track {
    animation: ticker-right var(--ticker-speed, 40s) linear infinite;
  }
  .ticker-item {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    white-space: nowrap;
    color: var(--color-bone);
    display: inline-flex;
    align-items: center;
    gap: 2.5rem;
  }
  .ticker--default .ticker-item {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 3vw, 2rem);
  }
  .ticker--raw .ticker-item {
    font-family: var(--font-raw);
    font-size: clamp(1.5rem, 4vw, 2.75rem);
    letter-spacing: 0.04em;
  }
  .ticker-dot {
    color: var(--color-accent);
  }
  @keyframes ticker-left {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }
  @keyframes ticker-right {
    from {
      transform: translateX(-50%);
    }
    to {
      transform: translateX(0);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .ticker-track {
      animation: none;
    }
  }
</style>
